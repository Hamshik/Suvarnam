{
	"tasks": [
		{
			"type": "process",
			"label": "build the Complier",
			"command": "./build.sh",
			"args": [],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"detail": "Task generated by Debugger.",
			"isBuildCommand": true
		},
		{
			"type": "process",
			"label": "run current .tq",
			"command": "${workspaceFolder}/bin/Complier",
			"args": [
				"${file}"
			],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"dependsOn": [
				"build the Complier"
			],
			"problemMatcher": []
		},
		{
			"label": "CMake: build",
            "type": "shell",
            "command": "cmake --build ${workspaceFolder}/build --target taca",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"]
		}
	],
	"version": "2.0.0"
}